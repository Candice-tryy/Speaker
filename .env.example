# Copy to .env.local and fill in. .env.local is gitignored.

# 讯飞 口语测评 ISE — read-aloud pronunciation scoring (跟读发音/流利度)
# Get these from https://console.xfyun.cn/ after creating an 语音评测(中英文) app.
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# DeepSeek (OpenAI-compatible) — phrases the single-point advice in Chinese.
# Reachable from mainland China. Get a key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# Optional: point at another OpenAI-compatible model (Qwen / 智谱 GLM ...)
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ASR / TTS providers — TBD (later step: open-ended 模拟作答 + 示范朗读)
# ASR_API_KEY=
# TTS_API_KEY=

# WeChat CloudBase question bank publishing.
# Used by: npm.cmd run bank:publish
CLOUD_ENV_ID=
TENCENTCLOUD_SECRETID=
TENCENTCLOUD_SECRETKEY=
